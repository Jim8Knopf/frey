# ==============================================================================
# SiYuan Notes Stack - Environment Variables (Auto-Generated)
# ==============================================================================
# This file is automatically generated by Ansible
# Contains all secrets needed for the notes stack
# ==============================================================================

# Domain Configuration
DOMAIN_NAME={{ network.domain_name }}
WIFI_IP={{ network.wifi.ip }}

# SiYuan OAuth/OIDC Configuration
SIYUAN_OAUTH_CLIENT_ID={{ notes.auth.oidc_client_id }}
SIYUAN_OAUTH_CLIENT_SECRET={{ siyuan_oidc_client_secret }}

# WebDAV Sync Password
SIYUAN_WEBDAV_PASSWORD={{ siyuan_webdav_password }}

# SiYuan Access Code (optional fallback authentication)
{% if siyuan_access_code is defined and siyuan_access_code != '' %}
SIYUAN_ACCESS_CODE={{ siyuan_access_code }}
{% else %}
SIYUAN_ACCESS_CODE=
{% endif %}

# Ollama AI Integration
OLLAMA_URL={{ notes.ai.ollama_url }}
OLLAMA_MODEL={{ notes.ai.model }}

